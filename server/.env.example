# ============================================
# 豆包 / 火山方舟 生图配置（必填）
# ============================================
# 在火山方舟控制台获取：https://console.volcengine.com/ark
# API Key 管理 → 创建 API Key
DOUBAO_API_KEY=在这里填入你的豆包API_Key

# 官方默认地址（一般不用改）
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# 生图模型（在控制台「模型推理」开通后复制模型 ID）
# 常用：doubao-seedream-4-0-250828 / doubao-seedream-4-5-251128
DOUBAO_IMAGE_MODEL=doubao-seedream-4-0-250828

# 输出尺寸：2K / 4K / 2048x2048
DOUBAO_IMAGE_SIZE=2K

# 生图引擎：doubao（推荐）/ pollinations（免费降级）/ openai
IMAGE_GEN_PROVIDER=doubao

# ============================================
# DeepSeek（可选，用于优化生图 prompt）
# ============================================
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-v4-flash

# ============================================
# 服务配置
# ============================================
HOST=0.0.0.0
PORT=8765
ADMIN_PASSWORD=请修改为你的强密码
DATABASE_URL=sqlite:///./lolida.db

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
